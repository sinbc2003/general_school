# ─── Secrets / Environment ───
# 절대 commit 금지 — JWT secret, 암호화 키, 관리자 비밀번호 포함
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/.venv/
backend/env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# ─── Node / Next.js ───
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts
.npm/

# ─── Databases (개발/테스트 데이터) ───
# DB는 각 환경에서 새로 생성되므로 commit 안 함
*.db
*.db-journal
*.sqlite
*.sqlite3
test_*.db

# ─── 사용자 업로드 파일 ───
# 학생 산출물·파비콘·연구 자료 등 운영 데이터
backend/storage/artifacts/
backend/storage/branding/
backend/storage/documents/
backend/storage/meetings/
backend/storage/assignments/
backend/storage/research/
# 빈 storage 폴더는 .gitkeep으로 구조만 유지

# ─── IDE / OS ───
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ───
*.log
logs/
npm-debug.log*
yarn-debug.log*
pip-log.txt

# ─── 빌드/배포 ───
dist/
build/
*.tar.gz
*.zip
.claude/
backend/*.db.empty-backup*
backend/*.db.backup*
