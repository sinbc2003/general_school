# ─── Secrets / Environment ───
# 절대 commit 금지 — JWT secret, 암호화 키, 관리자 비밀번호 포함
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/.venv/
backend/env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# ─── Node / Next.js ───
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts
.npm/

# ─── Databases (개발/테스트 데이터) ───
# DB는 각 환경에서 새로 생성되므로 commit 안 함
*.db
*.db-journal
*.sqlite
*.sqlite3
test_*.db

# ─── 사용자 업로드 파일 ───
# 학생 산출물·파비콘·연구 자료 등 운영 데이터 — storage 전체 차단
# (개별 나열은 새 섹션(boards/quiz 등) 추가 시 누락 → 학생 파일 커밋 위험)
backend/storage/*
!backend/storage/.gitkeep

# ─── IDE / OS ───
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ───
*.log
logs/
npm-debug.log*
yarn-debug.log*
pip-log.txt

# ─── 빌드/배포 ───
dist/
build/
*.tar.gz
*.zip
.claude/
backend/*.db.empty-backup*
backend/*.db.backup*
