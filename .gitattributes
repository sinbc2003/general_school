# Normalize all text files to LF in the repo (cross-platform clean diffs).
# Windows users still see CRLF on checkout via core.autocrlf if they want.
* text=auto eol=lf

# Windows shell scripts MUST be CRLF — cmd.exe silently fails on LF-only .bat
# (commands like pause / pushd are not recognized, window closes immediately).
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
