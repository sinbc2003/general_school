# ─── 환경 변수 템플릿 ───
# 이 파일을 복사해서 `.env`로 만들고 값을 채우세요.
#   cp .env.example .env
#
# .env는 .gitignore로 제외되므로 GitHub에 올라가지 않습니다.
# production 배포 시에는 반드시 모든 *_SECRET, *_KEY, *_PASSWORD를 강한 랜덤 값으로 교체하세요.

# ─── Database ───
DATABASE_URL=sqlite+aiosqlite:///general_school.db
# production:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ─── External services ───
REDIS_URL=redis://localhost:6379/0
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=change-me-random-string

# ─── 보안 (반드시 변경 필수) ───
# 생성 방법: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-with-random-32-bytes
ENCRYPTION_MASTER_KEY=change-me-with-random-32-bytes

# ─── Hocuspocus 협업 문서 서버 (선택 — 협업 문서 기능 쓸 때만) ───
# backend-hocuspocus/.env의 HOCUSPOCUS_INTERNAL_TOKEN과 정확히 일치 必.
# 비워두면 snapshot endpoint 503 (서비스 비활성).
# 운영: python -c "import secrets; print(secrets.token_urlsafe(32))" 로 강한 랜덤.
HOCUSPOCUS_INTERNAL_TOKEN=

# ─── 학교 정보 ───
SCHOOL_NAME=학교 이름
SCHOOL_SHORT=SCHOOL
PRIMARY_COLOR=#1a56db

# ─── 최고관리자 (초기 시드용. 첫 로그인 후 즉시 비밀번호 변경) ───
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=ChangeMe!Initial2026
SUPER_ADMIN_EMAIL=admin@school.local

# ─── URL ───
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8002
# production 예:
# FRONTEND_URL=https://school.example.com
# BACKEND_URL=https://school.example.com/api

# ─── CORS 허용 origin (콤마 구분) ───
# production은 학교 도메인만 화이트리스트 (와일드카드 X)
# production: 학교 도메인/IP로 변경. 예) http://10.0.0.5,http://gs.school.local
# dev 기본값: http://localhost:3000,http://localhost:3001
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
# production 예:
# CORS_ALLOW_ORIGINS=https://school.example.com

# ─── 2FA ───
TOTP_ISSUER=School Platform
TOTP_SESSION_MINUTES=30

# ─── 기본 비밀번호 (사용자 일괄 등록 시. 강제 변경 필요) ───
DEFAULT_USER_PASSWORD=ChangeMe!2026

# ─── 파일 저장 위치 (사용자 업로드) ───
# 기본(dev): backend/storage/ (상대경로, 코드 폴더 안 — dev 전용).
# production: 코드·OS와 분리된 절대경로 권장 (git pull 안 엮임, 백업 대상 명확).
#   예) STORAGE_ROOT=/home/susung/gs-data/storage
# setup-production.sh 실행 시 비어있으면 $HOME/gs-data/storage로 자동 추가.
# STORAGE_ROOT=storage

# ─── Frontend (선택) ───
# NEXT_PUBLIC_API_URL=http://localhost:8002
# 협업 문서 Hocuspocus WebSocket URL. dev 기본: ws://localhost:1234.
# production: wss://school.example.com/yjs (Caddy/nginx reverse-proxy 통과).
# NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234
