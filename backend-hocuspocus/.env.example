# Hocuspocus 서버 환경 변수 — backend FastAPI와 일치 必
#
# 운영 시: systemd Environment= 또는 docker -e 로 주입.
# 개발 시: 본 파일을 .env로 복사 후 채우기.

# WebSocket 포트
PORT=1234

# JWT — backend FastAPI의 JWT_SECRET과 정확히 일치해야 함 (HS256)
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256

# FastAPI base URL (snapshot/권한 조회)
FASTAPI_URL=http://localhost:8002

# FastAPI snapshot 저장 endpoint 인증 — backend의 HOCUSPOCUS_INTERNAL_TOKEN과 일치
HOCUSPOCUS_INTERNAL_TOKEN=dev-internal-token

# snapshot debounce (ms). DB IO 부하 vs in-memory ↔ DB 차이 균형.
# 60000 = 1분 (권장). 학교 환경 동시 사용자 80명 가정.
SNAPSHOT_DEBOUNCE_MS=60000

# 운영 환경 표시 (로그 분기용)
ENV=dev
